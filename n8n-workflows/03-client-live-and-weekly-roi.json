          { "node": "Respond OK", "type": "main", "index": 0 }
        ]
      ]
    },
    "Email - Go-Live to Client": {
      "main": [[{ "node": "CRM - Log Go-Live Activity", "type": "main", "index": 0 }]]
    },
    "Cron - Every Monday 9AM": {
      "main": [[{ "node": "CRM - Fetch Live Clients", "type": "main", "index": 0 }]]
    },
    "CRM - Fetch Live Clients": {
      "main": [[{ "node": "Split - Each Client", "type": "main", "index": 0 }]]
    },
    "Split - Each Client": {
      "main": [[{ "node": "IF - Has ROI Dashboard URL", "type": "main", "index": 0 }]]
    },
    "IF - Has ROI Dashboard URL": {
      "main": [[{ "node": "Email - Weekly ROI Report", "type": "main", "index": 0 }]]
    },
    "Email - Weekly ROI Report": {
      "main": [[{ "node": "CRM - Log ROI Report Activity", "type": "main", "index": 0 }]]
    }
  },
  "settings": { "executionOrder": "v1" }
}
