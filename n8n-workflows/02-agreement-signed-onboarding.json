        "fromEmail": "michael@revenuecs.com",
        "toEmail": "michael@revenuecs.com",
        "subject": "&#9989; New Client Signed — {{ $json.contactName }} | {{ $json.systemType }}",
        "emailFormat": "html",
        "message": "<!DOCTYPE html><html><body style=\"margin:0;padding:0;background:#f4f4f5;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;\">\n<table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\"><tr><td align=\"center\" style=\"padding:32px 20px;\">\n<table width=\"540\" cellpadding=\"0\" cellspacing=\"0\" style=\"background:#ffffff;border-radius:10px;overflow:hidden;box-shadow:0 2px 8px rgba(0,0,0,0.06);\">\n<tr><td style=\"background:#064e3b;padding:24px 32px;\">\n  <p style=\"margin:0;font-size:11px;font-weight:700;letter-spacing:0.12em;color:#6ee7b7;text-transform:uppercase;\">New Client — RevenueCS</p>\n  <h2 style=\"margin:6px 0 0;font-size:18px;font-weight:700;color:#ffffff;\">&#9989; {{ $json.contactName }} is in.</h2>\n</td></tr>\n<tr><td style=\"padding:28px 32px;\">\n  <table cellpadding=\"0\" cellspacing=\"0\" style=\"background:#f8fafc;border-radius:8px;width:100%;margin-bottom:20px;\">\n    <tr><td style=\"padding:16px 20px;\">\n      <p style=\"margin:0 0 10px;font-size:11px;font-weight:700;color:#6b7280;text-transform:uppercase;letter-spacing:0.08em;\">Client Details</p>\n      <p style=\"margin:0 0 4px;font-size:14px;color:#111827;\"><strong>Name:</strong> {{ $json.contactName }}</p>\n      <p style=\"margin:0 0 4px;font-size:14px;color:#111827;\"><strong>Email:</strong> {{ $json.contactEmail }}</p>\n      <p style=\"margin:0 0 4px;font-size:14px;color:#111827;\"><strong>Business:</strong> {{ $json.dealTitle }}</p>\n      <p style=\"margin:0 0 4px;font-size:14px;color:#111827;\"><strong>System:</strong> {{ $json.systemType }}</p>\n      <p style=\"margin:0 0 4px;font-size:14px;color:#111827;\"><strong>Setup fee:</strong> ${{ $json.setupFee }}</p>\n      <p style=\"margin:0 0 4px;font-size:14px;color:#111827;\"><strong>Monthly retainer:</strong> ${{ $json.monthlyRetainer }}/mo</p>\n      <p style=\"margin:0;font-size:14px;color:#6b7280;\"><strong>Client ID:</strong> {{ $json.clientId }}</p>\n    </td></tr>\n  </table>\n  <table cellpadding=\"0\" cellspacing=\"0\" style=\"background:#ecfdf5;border:1px solid #6ee7b7;border-radius:8px;width:100%;margin-bottom:20px;\">\n    <tr><td style=\"padding:14px 20px;\">\n      <p style=\"margin:0 0 8px;font-size:13px;font-weight:700;color:#065f46;\">Next steps</p>\n      <p style=\"margin:0 0 4px;font-size:13px;color:#065f46;\">&#9744; Wait for intake form submission (sent automatically to client)</p>\n      <p style=\"margin:0 0 4px;font-size:13px;color:#065f46;\">&#9744; Complete compliance review once intake arrives</p>\n      <p style=\"margin:0 0 4px;font-size:13px;color:#065f46;\">&#9744; Schedule kickoff call within 48 hours of intake submission</p>\n      <p style=\"margin:0;font-size:13px;color:#065f46;\">&#9744; Update client record in CaptureOS as onboarding progresses</p>\n    </td></tr>\n  </table>\n  <p style=\"margin:0;font-size:13px;color:#9ca3af;\">Client record auto-created in CaptureOS. Intake form + welcome email sent automatically via n8n.</p>\n</td></tr>\n</table></td></tr></table></body></html>",
        "options": {}
