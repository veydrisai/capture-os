      "parameters": {
        "fromEmail": "michael@revenuecs.com",
        "toEmail": "={{ $json.contactEmail }}",
        "subject": "You're in. Let's get to work.",
        "emailFormat": "html",
        "message": "<!DOCTYPE html><html><body style=\"margin:0;padding:0;background:#f4f4f5;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;\">\n<table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\"><tr><td align=\"center\" style=\"padding:40px 20px;\">\n<table width=\"560\" cellpadding=\"0\" cellspacing=\"0\" style=\"background:#ffffff;border-radius:12px;overflow:hidden;box-shadow:0 2px 12px rgba(0,0,0,0.08);\">\n<tr><td style=\"background:#0f0f0f;padding:32px 40px;\">\n  <p style=\"margin:0;font-size:13px;font-weight:600;letter-spacing:0.1em;color:#86efac;text-transform:uppercase;\">RevenueCS — Onboarding</p>\n  <h1 style=\"margin:8px 0 0;font-size:22px;font-weight:700;color:#ffffff;line-height:1.3;\">You're in. Complete your intake form to start your build.</h1>\n</td></tr>\n<tr><td style=\"padding:36px 40px;\">\n  <p style=\"margin:0 0 16px;font-size:15px;color:#374151;line-height:1.6;\">{{ $json.contactName }},</p>\n  <p style=\"margin:0 0 20px;font-size:15px;color:#374151;line-height:1.6;\">Your <strong>{{ $json.systemType }}</strong> system is in the build queue. To start, complete your intake form — it takes 10 minutes and is the only thing we need before we begin.</p>\n  <table cellpadding=\"0\" cellspacing=\"0\" style=\"margin-bottom:32px;\"><tr><td style=\"background:#6366f1;border-radius:8px;\">\n    <a href=\"{{ $json.intakeFormUrl }}\" style=\"display:inline-block;padding:14px 32px;color:#ffffff;text-decoration:none;font-size:15px;font-weight:600;\">Complete Your Intake Form &#8594;</a>\n  </td></tr></table>\n  <table cellpadding=\"0\" cellspacing=\"0\" style=\"background:#f9fafb;border-radius:8px;width:100%;margin-bottom:28px;\">\n    <tr><td style=\"padding:20px 24px;\">\n      <p style=\"margin:0 0 12px;font-size:12px;font-weight:600;color:#6b7280;text-transform:uppercase;letter-spacing:0.08em;\">What happens after you submit</p>\n      <p style=\"margin:0 0 8px;font-size:14px;color:#111827;\"><strong>1.</strong> Compliance review + kickoff call scheduled (within 48 hrs)</p>\n      <p style=\"margin:0 0 8px;font-size:14px;color:#111827;\"><strong>2.</strong> Build phase — scripting, VAPI config, Twilio setup, testing</p>\n      <p style=\"margin:0 0 8px;font-size:14px;color:#111827;\"><strong>3.</strong> Soft launch — live test with real calls</p>\n      <p style=\"margin:0;font-size:14px;color:#16a34a;font-weight:600;\">4. Full launch — system is live and dialing</p>\n    </td></tr>\n  </table>\n  <p style=\"margin:0 0 4px;font-size:14px;color:#374151;line-height:1.6;\">Questions? Reply to this email directly.</p>\n  <p style=\"margin:0;font-size:14px;color:#374151;\">— Michael</p>\n</td></tr>\n<tr><td style=\"background:#f9fafb;padding:20px 40px;border-top:1px solid #e5e7eb;\">\n  <p style=\"margin:0;font-size:13px;color:#9ca3af;\">Michael — RevenueCS &nbsp;&#183;&nbsp; michael@revenuecs.com</p>\n</td></tr>\n</table></td></tr></table></body></html>",
        "options": {}
      },
