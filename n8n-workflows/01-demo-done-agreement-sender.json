        "toEmail": "michael@revenuecs.com",
        "subject": "&#127919; Agreement Sent \u2014 {{ $json.contactName }} | {{ $json.systemType }}",
        "emailFormat": "html",
        "message": "<!DOCTYPE html><html><body style=\"margin:0;padding:0;background:#f4f4f5;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;\">\n<table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\"><tr><td align=\"center\" style=\"padding:32px 20px;\">\n<table width=\"540\" cellpadding=\"0\" cellspacing=\"0\" style=\"background:#ffffff;border-radius:10px;overflow:hidden;box-shadow:0 2px 8px rgba(0,0,0,0.06);\">\n<tr><td style=\"background:#1e1b4b;padding:24px 32px;\">\n  <p style=\"margin:0;font-size:11px;font-weight:700;letter-spacing:0.12em;color:#a5b4fc;text-transform:uppercase;\">Internal Alert \u2014 RevenueCS</p>\n  <h2 style=\"margin:6px 0 0;font-size:18px;font-weight:700;color:#ffffff;\">Agreement sent to {{ $json.contactName }}</h2>\n</td></tr>\n<tr><td style=\"padding:28px 32px;\">\n  <table cellpadding=\"0\" cellspacing=\"0\" style=\"background:#f8fafc;border-radius:8px;width:100%;margin-bottom:20px;\">\n    <tr><td style=\"padding:16px 20px;\">\n      <p style=\"margin:0 0 10px;font-size:11px;font-weight:700;color:#6b7280;text-transform:uppercase;letter-spacing:0.08em;\">Deal Summary</p>\n      <p style=\"margin:0 0 4px;font-size:14px;color:#111827;\"><strong>Contact:</strong> {{ $json.contactName }}</p>\n      <p style=\"margin:0 0 4px;font-size:14px;color:#111827;\"><strong>Email:</strong> {{ $json.contactEmail }}</p>\n      <p style=\"margin:0 0 4px;font-size:14px;color:#111827;\"><strong>System:</strong> {{ $json.systemType }}</p>\n      <p style=\"margin:0 0 4px;font-size:14px;color:#111827;\"><strong>Setup fee:</strong> ${{ $json.setupFee }}</p>\n      <p style=\"margin:0;font-size:14px;color:#111827;\"><strong>Monthly retainer:</strong> ${{ $json.monthlyRetainer }}/mo</p>\n    </td></tr>\n  </table>\n  <table cellpadding=\"0\" cellspacing=\"0\" style=\"background:#fef3c7;border:1px solid #f59e0b;border-radius:8px;width:100%;margin-bottom:20px;\">\n    <tr><td style=\"padding:14px 20px;\">\n      <p style=\"margin:0 0 4px;font-size:13px;font-weight:700;color:#92400e;\">Action required</p>\n      <p style=\"margin:0;font-size:13px;color:#92400e;line-height:1.5;\">Follow up within 24 hours if no signature. Log any responses in CaptureOS. Offer to answer questions \u2014 the most common hold-up is a clause question.</p>\n    </td></tr>\n  </table>\n  <p style=\"margin:0;font-size:13px;color:#6b7280;\">Agreement link sent: <a href=\"{{ $json.agreementTemplateUrl }}\" style=\"color:#6366f1;\">view document</a></p>\n</td></tr>\n</table></td></tr></table></body></html>",
        "options": {}
      },
